# LLM provider for the section-conversion step ("azure" | "anthropic").
PROVIDER=

# Azure endpoint URL for the section-conversion chat LLM.
AZURE_INFERENCE_ENDPOINT=
# API key for the section-conversion endpoint.
AZURE_INFERENCE_KEY=
# Deployment name of the section-conversion LLM.
AZURE_INFERENCE_MODEL_ID=
# API protocol: "chat" | "responses" | "azure-inference".
AZURE_INFERENCE_API_STYLE=

# Azure endpoint URL for the multimodal vision LLM (used by table rescue).
AZURE_VISION_ENDPOINT=
# API key for the vision endpoint.
AZURE_VISION_KEY=
# Deployment name of the vision LLM (e.g. a Kimi / GPT-4o-class model).
AZURE_VISION_MODEL=
# Vision API protocol: "chat" | "responses" | "azure-inference".
AZURE_VISION_API_STYLE=
# Per-page output cap for table-rescue extraction (default 16384). Bump if
# you see "[vision] WARNING: ... pages were truncated" on dense pages.
AZURE_VISION_MAX_TOKENS=
