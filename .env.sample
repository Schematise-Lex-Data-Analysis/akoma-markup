# Azure AI Services Configuration for akoma-markup
# Copy this file to .env and fill in your values

# Azure API Key (required for all Azure AI services)
# Get from: Azure Portal > AI Services > Keys and Endpoint
AZURE_API_KEY="your_azure_api_key_here"

# Document Intelligence (OCR) Endpoint
# Default: Azure Mistral OCR service
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT="https://***.services.ai.azure.com/providers/mistral/azure/ocr"

# Multimodal AI Endpoint (Grok/OpenAI-compatible)
# Default: Azure Grok endpoint
AZURE_MULTIMODAL_ENDPOINT="https://***.services.ai.azure.com/openai/v1/"

# Multimodal AI Deployment Name
# Default: Grok fast non-reasoning model
AZURE_MULTIMODAL_DEPLOYMENT="grok-4-1-fast-non-reasoning"

# Optional: Original akoma-markup LLM providers
# (For basic conversion functionality)

# For Anthropic Claude
ANTHROPIC_API_KEY="your_anthropic_api_key_here"
ANTHROPIC_MODEL_ID="claude-3-5-sonnet-20241022"

# For Azure OpenAI (original conversion)
AZURE_INFERENCE_ENDPOINT="your_azure_openai_endpoint"
AZURE_INFERENCE_CREDENTIAL="your_azure_openai_key"
AZURE_MODEL_ID="Llama-3.3-70B-Instruct"

# General provider setting (optional)
PROVIDER="azure"  # or "anthropic"